import time
from functools import wraps

def retry(times=3, delay=1):
    def deco(fn):
        @wraps(fn)
        def wrapper(*a, **k):
            last = None
            for _ in range(times):
                try:
                    return fn(*a, **k)
                except Exception as e:
                    last = e
                    time.sleep(delay)
            raise last
        return wrapper
    return deco
```

**Explanation:** Exponential backoff extension common in production.

