Q48. What is the output?
class MathOps:
    base = 10
    @classmethod
    def get_base(cls):
        return cls.base
    @staticmethod
    def add(x, y):
        return x + y
print(MathOps.get_base())
print(MathOps.add(5, MathOps.base))
m = MathOps()
print(m.get_base())
