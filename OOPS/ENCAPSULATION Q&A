Level 3: Hard
Q36. What is the output?
class A:
    def __init__(self):
        self.__x = 10
a = A()
print(a.__dict__)
# print(a.__x)
print(a._A__x)
A:
{'_A__x': 10}
# AttributeError for a.__x
10
